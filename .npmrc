# Allow installs even when peer-dep ranges don't strictly satisfy.
# Required for this monorepo because the web preview (root) and the mobile
# app (apps/mobile) have different sets of React Native / MUI / Radix peer
# expectations that can shift between minor versions. Without this flag,
# EAS Build's `npm ci` fails on transient peer mismatches that don't
# actually break either runtime.
legacy-peer-deps=true
